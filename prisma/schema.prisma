// ============================================================
// Restaurant POS — Prisma Schema
// Phase 1: Foundation
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  MANAGER
  CASHIER
  WAITER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  BILLING
}

enum OrderType {
  DINE_IN
  TAKEOUT
  DELIVERY
}

enum OrderStatus {
  PENDING
  ACTIVE
  SERVED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  COOKING
  SERVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  GCASH
  MAYA
  OTHER_EWALLET
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

// ============================================================
// USERS
// ============================================================

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  pin          String?  // 4-digit PIN for quick cashier login
  role         Role     @default(WAITER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  orders       Order[]  // Orders taken by this staff

  @@map("users")
}

// ============================================================
// MENU
// ============================================================

model Category {
  id          String     @id @default(uuid())
  name        String
  description String?
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  isDiscountable Boolean @default(true) @map("is_discountable")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  menuItems   MenuItem[]

  @@map("categories")
}

model MenuItem {
  id            String          @id @default(uuid())
  categoryId    String          @map("category_id")
  name          String
  description   String?
  price         Decimal         @db.Decimal(10, 2)
  imageUrl      String?         @map("image_url")
  isAvailable   Boolean         @default(true) @map("is_available")
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  category        Category        @relation(fields: [categoryId], references: [id])
  modifierGroups  ModifierGroup[]
  orderItems      OrderItem[]
  menuItemIngredients MenuItemIngredient[]
  setComponentsAsParent   SetMealComponent[]    @relation("SetMealParent")
  setComponentsAsChild    SetMealComponent[]    @relation("SetMealComponent")
  orderItemComponents     OrderItemComponent[]

  @@map("menu_items")
}

model ModifierGroup {
  id          String     @id @default(uuid())
  menuItemId  String     @map("menu_item_id")
  name        String     // e.g. "Choose Size", "Add-ons"
  isRequired  Boolean    @default(false) @map("is_required")
  minSelect   Int        @default(0) @map("min_select")
  maxSelect   Int        @default(1) @map("max_select")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  menuItem    MenuItem   @relation(fields: [menuItemId], references: [id])
  modifiers   Modifier[]

  @@map("modifier_groups")
}

model Modifier {
  id                String              @id @default(uuid())
  modifierGroupId   String              @map("modifier_group_id")
  name              String              // e.g. "Large", "Extra Rice"
  additionalPrice   Decimal             @default(0) @db.Decimal(10, 2) @map("additional_price")
  createdAt         DateTime            @default(now()) @map("created_at")

  // Relations
  modifierGroup       ModifierGroup         @relation(fields: [modifierGroupId], references: [id])
  orderItemModifiers  OrderItemModifier[]

  @@map("modifiers")
}

// ============================================================
// TABLES
// ============================================================

model Table {
  id                String      @id @default(uuid())
  tableNumber       String      @unique @map("table_number") // e.g. "T1", "T2"
  capacity          Int         @default(4)
  status            TableStatus @default(AVAILABLE)
  floorSection      String?     @map("floor_section") // e.g. "Ground Floor", "2nd Floor", "Outdoor"
  mergedWithTableId String?     @map("merged_with_table_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  // Relations
  mergedWithTable   Table?        @relation("TableMerge", fields: [mergedWithTableId], references: [id])
  mergedTables      Table[]       @relation("TableMerge")
  orders            Order[]
  reservations      Reservation[]

  @@map("tables")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id            String      @id @default(uuid())
  tableId       String?     @map("table_id")
  userId        String      @map("user_id")
  orderType     OrderType   @default(DINE_IN) @map("order_type")
  status        OrderStatus @default(PENDING)
  notes         String?
  orNumber Int? @unique @map("or_number")

  // Billing fields
  subtotal      Decimal?    @db.Decimal(10, 2)
  taxAmount     Decimal?    @db.Decimal(10, 2) @map("tax_amount")
  discountAmount Decimal?   @default(0) @db.Decimal(10, 2) @map("discount_amount")
  promoCode     String?     @map("promo_code")
  totalAmount   Decimal?    @db.Decimal(10, 2) @map("total_amount")
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Relations
  table         Table?       @relation(fields: [tableId], references: [id])
  user          User         @relation(fields: [userId], references: [id])
  orderItems    OrderItem[]
  payments      Payment[]

  @@map("orders")
}

model OrderItem {
  id          String          @id @default(uuid())
  orderId     String          @map("order_id")
  menuItemId  String          @map("menu_item_id")
  quantity    Int             @default(1)
  unitPrice   Decimal         @db.Decimal(10, 2) @map("unit_price")  // price at time of order
  subtotal    Decimal         @db.Decimal(10, 2)                       // unitPrice * quantity + modifiers
  notes       String?
  status      OrderItemStatus @default(PENDING)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  order               Order               @relation(fields: [orderId], references: [id])
  menuItem            MenuItem            @relation(fields: [menuItemId], references: [id])
  orderItemModifiers  OrderItemModifier[]
  components          OrderItemComponent[]

  @@map("order_items")
}

model OrderItemModifier {
  id              String    @id @default(uuid())
  orderItemId     String    @map("order_item_id")
  modifierId      String    @map("modifier_id")
  name            String    // snapshot of modifier name at order time
  additionalPrice Decimal   @db.Decimal(10, 2) @map("additional_price")
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  modifier    Modifier  @relation(fields: [modifierId], references: [id])

  @@map("order_item_modifiers")
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @map("order_id")
  method        PaymentMethod
  amount        Decimal       @db.Decimal(10, 2)
  referenceNo   String?       @map("reference_no") // for card/gcash transaction reference
  receivedBy    String        @map("received_by")  // userId of cashier
  createdAt     DateTime      @default(now()) @map("created_at")

  // Relations
  order         Order         @relation(fields: [orderId], references: [id])

  @@map("payments")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Promo {
  id            String       @id @default(uuid())
  code          String       @unique
  description   String?
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @db.Decimal(10, 2) @map("discount_value")
  minOrderAmount Decimal?    @db.Decimal(10, 2) @map("min_order_amount")
  maxUses       Int?         @map("max_uses")
  usedCount     Int          @default(0) @map("used_count")
  isActive      Boolean      @default(true) @map("is_active")
  expiresAt     DateTime?    @map("expires_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@map("promos")
}

enum StockUnit {
  G
  KG
  ML
  L
  PCS
  DOZEN
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  WASTE
}

model Ingredient {
  id              String    @id @default(uuid())
  name            String
  unit            StockUnit
  currentStock    Decimal   @default(0) @db.Decimal(10, 3) @map("current_stock")
  lowStockAlert   Decimal   @default(0) @db.Decimal(10, 3) @map("low_stock_alert")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  menuItemIngredients MenuItemIngredient[]
  stockMovements      StockMovement[]

  @@map("ingredients")
}

model MenuItemIngredient {
  id           String     @id @default(uuid())
  menuItemId   String     @map("menu_item_id")
  ingredientId String     @map("ingredient_id")
  quantity     Decimal    @db.Decimal(10, 3)

  // Relations
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([menuItemId, ingredientId])
  @@map("menu_item_ingredients")
}

model StockMovement {
  id           String            @id @default(uuid())
  ingredientId String            @map("ingredient_id")
  type         StockMovementType
  quantity     Decimal           @db.Decimal(10, 3)
  notes        String?
  orderId      String?           @map("order_id")
  createdBy    String            @map("created_by")
  createdAt    DateTime          @default(now()) @map("created_at")

  // Relations
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@map("stock_movements")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  CANCELLED
  NO_SHOW
}

model Reservation {
  id           String            @id @default(uuid())
  tableId      String?           @map("table_id")
  guestName    String            @map("guest_name")
  guestPhone   String?           @map("guest_phone")
  partySize    Int               @map("party_size")
  reservedAt   DateTime          @map("reserved_at")
  notes        String?
  status       ReservationStatus @default(PENDING)
  createdBy    String            @map("created_by")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  // Relations
  table        Table?            @relation(fields: [tableId], references: [id])

  @@map("reservations")
}

model SetMealComponent {
  id             String   @id @default(uuid())
  setMenuItemId  String   @map("set_menu_item_id")
  componentId    String   @map("component_id")
  quantity       Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at")

  setMenuItem    MenuItem @relation("SetMealParent", fields: [setMenuItemId], references: [id])
  component      MenuItem @relation("SetMealComponent", fields: [componentId], references: [id])

  @@map("set_meal_components")
}

model OrderItemComponent {
  id             String    @id @default(uuid())
  orderItemId    String    @map("order_item_id")
  componentId    String    @map("component_id")
  quantity       Int       @default(1)
  isSubstituted  Boolean   @default(false) @map("is_substituted")
  createdAt      DateTime  @default(now()) @map("created_at")

  orderItem      OrderItem @relation(fields: [orderItemId], references: [id])
  component      MenuItem  @relation(fields: [componentId], references: [id])

  @@map("order_item_components")
}

enum VoidType {
  ITEM
  ORDER
}

model VoidLog {
  id             String    @id @default(uuid())
  type           VoidType
  orderId        String    @map("order_id")
  orderItemId    String?   @map("order_item_id")
  itemName       String    @map("item_name")
  quantity       Int
  amount         Decimal   @db.Decimal(10, 2)
  reason         String
  voidedBy       String    @map("voided_by")       // staff who requested the void
  approvedBy     String    @map("approved_by")     // manager/admin who approved via PIN
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("void_logs")
}

enum ShiftStatus {
  OPEN
  CLOSED
}

model Shift {
  id              String      @id @default(uuid())
  openedBy        String      @map("opened_by")
  closedBy        String?     @map("closed_by")
  startingCash    Decimal     @db.Decimal(10, 2) @map("starting_cash")
  endingCashCounted Decimal?  @db.Decimal(10, 2) @map("ending_cash_counted")
  expectedCash    Decimal?    @db.Decimal(10, 2) @map("expected_cash")
  overShort       Decimal?    @db.Decimal(10, 2) @map("over_short")
  status          ShiftStatus @default(OPEN)
  notes           String?
  openedAt        DateTime    @default(now()) @map("opened_at")
  closedAt        DateTime?   @map("closed_at")

  @@map("shifts")
}

model OrNumberCounter {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("or_number_counter")
}